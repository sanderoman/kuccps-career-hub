{
  "version": 2,
  "name": "kuccps-career-hub",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://kuccps-api.vercel.app/api"
  }
}
