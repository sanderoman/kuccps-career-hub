{
  "version": 2,
  "name": "kuccps-career-hub",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://kuccps-api.vercel.app/api"
  },
  "framework": "create-react-app",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "buildCommand": "npm run build"
}
