{
  "version": 2,
  "name": "kuccps-api",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "JWT_SECRET_KEY": "2025",
    "CORS_ORIGINS": "*",
    "PORT": "5000"
  },
  "functions": {
    "app.py": {
      "runtime": "python3.9",
      "maxDuration": 10
    }
  }
}
